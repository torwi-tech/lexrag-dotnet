<?xml version="1.0" encoding="utf-8"?>
<!-- Isolate this public portfolio repo from any machine-global / client-private feeds:
     clear inherited sources and use only nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
